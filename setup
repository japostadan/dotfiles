#!/bin/bash
set -euo pipefail

echo "[*] Running cross-platform setup..."

# Ensure ~/.local/bin is on PATH throughout this script
export PATH="$HOME/.local/bin:$PATH"

# Detect OS
OS="$(uname -s)"
case "$OS" in
    Linux*)     PLATFORM="linux";;
    Darwin*)    PLATFORM="macos";;
    *)          echo "[!] Unsupported platform: $OS" && exit 1;;
esac

echo "[*] Platform detected: $PLATFORM"

# ── macOS only: install Homebrew + GUI-level packages ────────────────────────
# On Linux (especially shared/no-sudo machines) we skip system packages entirely
# and rely on mise to install everything to ~/.local/bin.
if [[ "$PLATFORM" == "macos" ]]; then
    if ! command -v brew >/dev/null; then
        echo "[*] Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        # Activate brew for the rest of this script
        if [[ -f /opt/homebrew/bin/brew ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        elif [[ -f /usr/local/bin/brew ]]; then
            eval "$(/usr/local/bin/brew shellenv)"
        fi
    fi
    # git and curl are baseline deps; tmux/kitty are managed by mise/app install
    brew install --quiet git curl tmux kitty 2>/dev/null || true
fi

# ── Linux: print helpful message if system deps are missing ──────────────────
if [[ "$PLATFORM" == "linux" ]]; then
    for dep in git curl bash; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            echo "[!] Required tool '$dep' not found."
            echo "    Ask your sysadmin to install it, or run:"
            echo "    apt-get install -y $dep  (if you have sudo)"
        fi
    done
fi

# ── Install mise (no sudo required — installs to ~/.local/bin) ───────────────
if ! command -v mise >/dev/null 2>&1; then
    echo "[*] Installing mise..."
    curl -fsSL https://mise.run | MISE_INSTALL_PATH="$HOME/.local/bin/mise" bash
fi

echo "[+] mise: $(mise --version)"

# ── Install all tools via mise (no sudo anywhere) ────────────────────────────
if [[ -f "$HOME/.config/mise/config.toml" ]]; then
    echo "[*] Installing mise tools from ~/.config/mise/config.toml ..."
    mise trust "$HOME/.config/mise/config.toml" 2>/dev/null || true
    mise install
else
    echo "[!] No mise config found at ~/.config/mise/config.toml — skipping tool install."
fi

# ── Install nvm + Node.js (no sudo required) ─────────────────────────────────
if [[ ! -d "$HOME/.nvm" ]]; then
    echo "[*] Installing nvm..."
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/HEAD/install.sh | bash
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

if ! node --version >/dev/null 2>&1; then
    echo "[*] Installing Node.js LTS via nvm..."
    nvm install --lts
    nvm alias default node
fi

echo "[+] Setup complete. Open a new shell or run: exec zsh"
